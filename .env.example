# app
NEXT_PUBLIC_APP_URL="https://www.xparse.ai"
NEXT_PUBLIC_APP_NAME="xparse"

# theme
NEXT_PUBLIC_THEME="default"

# appearance
NEXT_PUBLIC_APPEARANCE="system"

# auth secret (generate: openssl rand -base64 32)
AUTH_SECRET=""

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED="true"
NEXT_PUBLIC_AUTH_GOOGLE_ONE_TAP_ENABLED="true"
NEXT_PUBLIC_AUTH_GOOGLE_ID=""

# TextIn document parsing API
TEXTIN_APP_ID=""
TEXTIN_APP_SECRET=""
# Optional: self-hosted proxy
# TEXTIN_PROXY_URL=""
# TEXTIN_PROXY_SECRET=""

# Webhook base URL (same as NEXT_PUBLIC_APP_URL)
WEBHOOK_BASE_URL="https://www.xparse.ai"

# Cloudflare R2 storage
TIMI_R2_ACCOUNT_ID=""
TIMI_R2_BUCKET_NAME=""
TIMI_R2_ACCESS_KEY_ID=""
TIMI_R2_SECRET_ACCESS_KEY=""
TIMI_R2_ENDPOINT=""
TIMI_R2_TOKEN=""
TIMI_R2_PUBLIC_URL=""

# Supabase (REST API)
NEXT_PUBLIC_TIMI_SUPABASE_URL=""
NEXT_PUBLIC_TIMI_SUPABASE_PUBLISHABLE_KEY=""
TIMI_SUPABASE_SERVICE_KEY=""

# Database (Supabase Postgres via Drizzle ORM)
DATABASE_PROVIDER="postgresql"
DATABASE_URL=""
DB_SINGLETON_ENABLED="true"
DB_MAX_CONNECTIONS="1"

# Google Translate API (optional, for VLM Chinese description translation)
GOOGLE_TRANSLATE_API_KEY=""

# Resend email (optional, for email verification)
RESEND_API_KEY=""
RESEND_SENDER_EMAIL=""
